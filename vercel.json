{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "build": {
    "env": {
      "VERCEL_ANALYZE_BUILD_OUTPUT": "1"
    }
  },
  "installCommand": "bash avp.sh",
  "functions": {
    "api/main.py": {
      "runtime": "@vercel/python@6.1.5",
      "maxDuration": 300,
      "memory": 2048,
      "excludeFiles": "bin/deno"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "api/main.py" }
  ]
}
